{
  "manifest_version": 3,
  "name": "Enhancer",
  "version": "3.5.0",
  "description": "Agenda, couleurs, personnalisation complète du Portail & Moodle",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "portal-refound@houlock.be",
      "strict_min_version": "140.0"
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "host_permissions": [
    "*://portail.henallux.be/*",
    "*://moodle.henallux.be/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://portail.henallux.be/*",
        "*://moodle.henallux.be/*"
      ],
      "js": [
        "themes.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}